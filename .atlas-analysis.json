    "SceytChatUIKit.chatTokenProvider: ChatTokenProvider",
    "SceytChatUIKit.messageTransformer: MessageTransformer",
    "SceytChatUIFacade.channelInteractor: ChannelInteractor",
    "SceytChatUIFacade.messageInteractor: MessageInteractor",
    "SceytChatUIFacade.userInteractor: UserInteractor",
    "SceytChatUIFacade.attachmentInteractor: AttachmentInteractor",
