  "keyFeatures": [
    "Prebuilt channel list, message list, and channel info UI components",
    "Full offline support with local database caching and automatic sync",
    "Deep style customization via StyleCustomizer and StyleRegistry for every UI component",
    "Voice message recording and playback built in",
    "Photo and video resizing on-device with adjustable quality parameters",
    "Light/dark mode support",
    "Firebase push notification integration with customizable notification builders",
    "Custom navigation system via SceytChatUIKitNavigator and Destination sealed class",
    "Pluggable formatters, providers, and renderers for text, avatars, and icons",
    "Poll creation and results support",
    "Message reactions, mentions, threading, and forwarding",
    "Self-destructing media messages"
  ],
  "publicApiSurface": [
    "SceytChatUIKit.initialize(appContext, apiUrl, appId, clientId, enableDatabase)",
    "SceytChatUIKit.connect(token)",
    "SceytChatUIKit.reconnect()",
    "SceytChatUIKit.disconnect()",
    "SceytChatUIKit.logOut(unregisterPushCallback)",
